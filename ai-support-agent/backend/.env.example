# ─── Database (Supabase) ──────────────────────────────────────────
DATABASE_URL="postgresql://postgres:[password]@db.[project].supabase.co:5432/postgres"

# ─── AI ───────────────────────────────────────────────────────────
GROQ_API_KEY="gsk_..."
GEMINI_API_KEY="AIza..."

# ─── Redis (Upstash) ──────────────────────────────────────────────
UPSTASH_REDIS_REST_URL="https://..."
UPSTASH_REDIS_REST_TOKEN="..."

# ─── Auth ─────────────────────────────────────────────────────────
JWT_SECRET="your-super-secret-key"
JWT_REFRESH_SECRET="your-refresh-secret"
# Encrypts tenant BYOK API keys at rest (32+ random characters)
ENCRYPTION_KEY="your-encryption-key-min-32-chars"

# ─── Cloudinary ───────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME="..."
CLOUDINARY_API_KEY="..."
CLOUDINARY_API_SECRET="..."

# ─── App ──────────────────────────────────────────────────────────
NODE_ENV="development"
PORT=5000
CLIENT_URL="http://localhost:5173"
# Comma-separated extra dashboard origins (e.g. production Vercel URL)
# ALLOWED_ORIGINS="https://your-app.vercel.app"
# Set true when deployed behind Railway/Render/nginx (needed for rate limits)
TRUST_PROXY="false"

# ─── Email (optional — logs to console in dev) ────────────────────
# RESEND_API_KEY="re_..."
# EMAIL_FROM="SupportDesk <noreply@yourdomain.com>"
